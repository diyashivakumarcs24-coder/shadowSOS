<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calc_bg">

    <TextView
        android:id="@+id/tvExpression"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#8E8E93"
        android:textSize="20sp"
        android:gravity="end"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:maxLines="1"
        android:ellipsize="start"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvDisplay"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="1.0" />

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="@color/text_primary"
        android:textSize="72sp"
        android:fontFamily="sans-serif-light"
        android:gravity="end"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        android:maxLines="1"
        android:ellipsize="start"
        app:layout_constraintTop_toBottomOf="@id/tvExpression"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnGrid" />

    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/btnGrid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:columnCount="4"
        app:rowCount="5">

        <TextView android:id="@+id/btnAC" android:text="AC" android:textColor="@color/bg_primary" android:textSize="22sp" android:fontFamily="sans-serif-medium" android:gravity="center" android:background="@drawable/bg_calc_button_action" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btnPlusMinus" android:text="+/-" android:textColor="@color/bg_primary" android:textSize="22sp" android:fontFamily="sans-serif-medium" android:gravity="center" android:background="@drawable/bg_calc_button_action" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btnPercent" android:text="%" android:textColor="@color/bg_primary" android:textSize="22sp" android:fontFamily="sans-serif-medium" android:gravity="center" android:background="@drawable/bg_calc_button_action" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btnDivide" android:text="÷" android:textColor="@color/text_primary" android:textSize="28sp" android:gravity="center" android:background="@drawable/bg_calc_button_operator" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />

        <TextView android:id="@+id/btn7" android:text="7" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btn8" android:text="8" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btn9" android:text="9" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btnMultiply" android:text="×" android:textColor="@color/text_primary" android:textSize="28sp" android:gravity="center" android:background="@drawable/bg_calc_button_operator" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />

        <TextView android:id="@+id/btn4" android:text="4" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btn5" android:text="5" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btn6" android:text="6" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btnMinus" android:text="−" android:textColor="@color/text_primary" android:textSize="28sp" android:gravity="center" android:background="@drawable/bg_calc_button_operator" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />

        <TextView android:id="@+id/btn1" android:text="1" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btn2" android:text="2" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btn3" android:text="3" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btnPlus" android:text="+" android:textColor="@color/text_primary" android:textSize="28sp" android:gravity="center" android:background="@drawable/bg_calc_button_operator" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />

        <TextView android:id="@+id/btn0" android:text="0" android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="start|center_vertical" android:paddingStart="28dp" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="2" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btnDot" android:text="." android:textColor="@color/text_primary" android:textSize="26sp" android:gravity="center" android:background="@drawable/bg_calc_button_number" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />
        <TextView android:id="@+id/btnEquals" android:text="=" android:textColor="@color/text_primary" android:textSize="28sp" android:gravity="center" android:background="@drawable/bg_calc_button_operator" android:layout_width="0dp" android:layout_height="0dp" app:layout_columnWeight="1" app:layout_rowWeight="1" android:layout_margin="6dp" android:minHeight="72dp" />

    </androidx.gridlayout.widget.GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
